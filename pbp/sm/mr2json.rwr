% rewrite mr2json {
  Top [name lb Array+ rb] = ‛[«Array»]’
  Array [name lb attr* Object+ rb] = ‛\n"«name»" : {«attr»\n[«Object»]}’
  attr [name eq str] = ‛\n«name»«eq»«str»,’
  Object [name lb attr+ rb] = ‛\n"«name»" : {«attr»},’
  name [uletter ualnum*] = ‛«uletter»«ualnum»’
  uletter [c] = ‛«c»’
  ualnum [c] = ‛«c»’
  str [lq cs* rq] = ‛«lq»«cs»«rq»’
}
